EXPO_PUBLIC_API_URL=http://localhost:8080/api
EXPO_PUBLIC_AI_API_URL=http://localhost:8080/api
EXPO_PUBLIC_APP_ENV=development

# Play Store / production (EAS secrets veya .env.production)
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://example.com/privacy
# EXPO_PUBLIC_SUPPORT_EMAIL=destek@example.com
# EXPO_PUBLIC_TERMS_URL=https://example.com/terms

# Opsiyonel: Gerçek AI tanıma için Gemini API key (backend ortam değişkeni)
# GEMINI_API_KEY=...

# Android emulator için:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/api
