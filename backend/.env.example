# PostgreSQL (docker compose defaults)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nereden
DB_USER=nereden
DB_PASSWORD=nereden

# API
SERVER_PORT=8080
JWT_SECRET=change-me-in-development-use-at-least-256-bits

# Storage
UPLOAD_DIR=./uploads
STORAGE_BASE_URL=http://localhost:8080/api/files

# CORS (Expo dev server)
CORS_ORIGINS=http://localhost:8081,exp://localhost:8081

